.hero h1 span {
  color: #fff;
  font-size: 1.3em;
}
.carousel {
  width: 100%;
  overflow: hidden;
  background: #000;
}

.slides {
  display: flex;
  transition: transform 0.8s ease-in-out;
}

.slides img {
  width: 100%;
  height: auto;      /* 🔥 mantiene proporción real */
  flex: 0 0 100%;
  display: block;
}
