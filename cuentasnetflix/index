<script>
  const searchToggle = document.getElementById("searchToggle");
  const searchBar = document.getElementById("searchBar");
  const searchInput = document.getElementById("searchInput");

  const hero = document.getElementById("hero");
  const frase = document.getElementById("frase");
  const destacadoTitle = document.getElementById("destacado-title");

  const resultTitle = document.getElementById("result-title");
  const noResults = document.getElementById("no-results");

  searchToggle.addEventListener("click", () => {
    searchBar.style.display = searchBar.style.display === "block" ? "none" : "block";
    searchInput.focus();
  });

  searchInput.addEventListener("keyup", () => {
    const term = searchInput.value.toLowerCase().trim();
    let found = false;

    document.querySelectorAll(".producto").forEach(card => {
      const name = card.textContent.toLowerCase();
      if (term !== "" && name.includes(term)) {
        card.style.display = "block";
        found = true;
      } else if (term === "") {
        card.style.display = "block";
      } else {
        card.style.display = "none";
      }
    });

    if (term === "") {
      hero.style.display = "block";
      frase.style.display = "block";
      destacadoTitle.style.display = "block";
      resultTitle.style.display = "none";
      noResults.style.display = "none";
    } else if (found) {
      hero.style.display = "none";
      frase.style.display = "none";
      destacadoTitle.style.display = "none";
      resultTitle.style.display = "block";
      noResults.style.display = "none";
    } else {
      hero.style.display = "none";
      frase.style.display = "none";
      destacadoTitle.style.display = "none";
      resultTitle.style.display = "none";
      noResults.style.display = "block";
    }
  });
  
function filterCategory(category) {
  const cards = document.querySelectorAll(".producto");
  const destacadoTitle = document.getElementById("destacado-title");
  const hero = document.getElementById("hero");
  const frase = document.getElementById("frase");

  hero.style.display = "none";
  frase.style.display = "none";
  destacadoTitle.style.display = "none";

  cards.forEach(card => {
    if (card.dataset.category === category) {
      card.style.display = "block";
    } else {
      card.style.display = "none";
    }
  });
}

function showDestacados() {
  const cards = document.querySelectorAll(".producto");
  const destacadoTitle = document.getElementById("destacado-title");
  const hero = document.getElementById("hero");
  const frase = document.getElementById("frase");

  hero.style.display = "block";
  frase.style.display = "block";
  destacadoTitle.style.display = "block";

  cards.forEach(card => {
    const id = card.querySelector(".product")?.dataset.id;
    if (id && products[id].featured) {
      card.style.display = "block";
    } else {
      card.style.display = "none";
    }
  });
}

document.addEventListener("DOMContentLoaded", () => {
  showDestacados();
});

</script>
